#!/usr/bin/env bash
# Remove Zone.Identifier files (Windows/WSL download markers) from the project.
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

mapfile -d '' -t files < <(find "$root" -type f -name '*:Zone.Identifier' -print0)

if [ "${#files[@]}" -eq 0 ]; then
  echo "No Zone.Identifier files found under $root"
  exit 0
fi

for f in "${files[@]}"; do
  echo "Removing $f"
  rm -f -- "$f"
done

echo "Removed ${#files[@]} Zone.Identifier file(s)."
